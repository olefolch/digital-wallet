{
  "Jwt": {
    "Secret": "",
    "Issuer": "digital-wallet",
    "Audience": "digital-wallet"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/v1/auth/{**catch-all}" }
      },
      "accounts-route": {
        "ClusterId": "accounts-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/v1/accounts/{**catch-all}" }
      },
      "transactions-route": {
        "ClusterId": "transactions-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": { "Path": "/api/v1/transactions/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": { "Address": "http://localhost:5001/" }
        }
      },
      "accounts-cluster": {
        "Destinations": {
          "account-service": { "Address": "http://localhost:5002/" }
        }
      },
      "transactions-cluster": {
        "Destinations": {
          "transaction-service": { "Address": "http://localhost:5003/" }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  }
}